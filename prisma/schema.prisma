generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  entries      Entry[]
  goals        GoalHistory[]
}

model Entry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodName  String
  calories  Int
  protein   Int      @default(0)
  timestamp DateTime
  createdAt DateTime @default(now())
}

model GoalHistory {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calorieGoal    Int
  proteinGoal    Int
  mode           GoalMode @default(MAINTAIN)
  effectiveFrom  DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([userId, effectiveFrom])
}

enum GoalMode {
  DEFICIT
  MAINTAIN
  SURPLUS
}
